# 环境变量配置示例
# 复制此文件为 .env 并填入你的 API 密钥

# ============================================
# Brave Search API（可选）
# ============================================
# 用于 L0 网络搜索
# 获取方式：https://brave.com/api/
# 免费额度：2000次/月
BRAVE_API_KEY=your_brave_api_key_here

# ============================================
# OpenClaw 配置（可选）
# ============================================
# 自定义 Gateway 端口（默认 18789）
# OPENCLAW_PORT=18789

# 自定义工作目录
# OPENCLAW_WORKSPACE=~/.openclaw/workspace
